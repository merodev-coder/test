# Backend Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Server Configuration
PORT=5001
NODE_ENV=development

# Database
MONGODB_URI=your_mongodb_connection_string_here

# JWT Authentication
JWT_SECRET=your_strong_random_secret_here_min_32_chars

# Admin Credentials
# Generate password hash using: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_bcrypt_hashed_password_here

# Frontend URL for CORS
FRONTEND_URL=http://localhost:4028

# Bosta Shipping API (if using)
BOSTA_API_URL=https://stg-app.bosta.co/api/v2
BOSTA_API_KEY=your_bosta_api_key_here
BOSTA_PICKUP_ADDRESS_ID=your_pickup_address_id_here

# File Upload (Upload Thing)
UPLOADTHING_TOKEN=your_uploadthing_token_here
