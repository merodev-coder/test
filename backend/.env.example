MONGODB_URI=your_mongodb_connection_string
PORT=5001

# Email credentials for sending order receipts
# Use a Gmail account with an App Password (not your regular password)
# To generate App Password: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Bosta API integration
# Get your API key from Bosta dashboard: https://dashboard.bosta.co/
BOSTA_API_KEY=your_bosta_api_key_here
